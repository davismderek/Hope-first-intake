# =============================================================================
# Hope First Intake Wizard - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# DrChrono OAuth
# -----------------------------------------------------------------------------
# Get these from https://app.drchrono.com/api-management/
# NOTE: Access tokens are NOT stored here. They are managed via the OAuth flow
# and persisted in the token store. Visit /admin/drchrono to connect.
DRCHRONO_CLIENT_ID=your_client_id
DRCHRONO_CLIENT_SECRET=your_client_secret
DRCHRONO_REDIRECT_URI=http://localhost:3000/api/drchrono/callback

# Optional: override default scopes
# DRCHRONO_SCOPES=patients:read patients:write calendar:read calendar:write clinical:read clinical:write

# DrChrono doctor/office IDs for appointment creation
DRCHRONO_DOCTOR_ID=
DRCHRONO_OFFICE_ID=
DRCHRONO_EXAM_ROOM=

# Set to "true" to use mock data instead of live DrChrono API
DRCHRONO_MOCK_MODE=true

# -----------------------------------------------------------------------------
# Token Store
# -----------------------------------------------------------------------------
# LOCAL DEV: encrypts the local OAuth token file (.drchrono-tokens.enc).
# Must be at least 32 characters. Only needed when Upstash vars are not set.
TOKEN_STORE_SECRET=change-me-to-a-random-32-char-string!!

# PRODUCTION (Vercel): Upstash Redis stores OAuth tokens durably.
# Get these from https://console.upstash.com — your Redis database details page.
# When these are set, the app automatically uses Upstash instead of the local file.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
